// ═══════════════════════════════════════════════════════════
// Prisma Schema — CvBuilder
// ═══════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ── Enums ────────────────────────────────────────────────

enum CVStatus {
  DRAFT
  PUBLISHED
}

enum SkillCategory {
  TECHNICAL
  SOFT
  LANGUAGE
  TOOL
  FRAMEWORK
  OTHER
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LanguageProficiency {
  NATIVE
  BILINGUAL
  FULL_PROFESSIONAL
  PROFESSIONAL_WORKING
  LIMITED_WORKING
  ELEMENTARY
}

enum TemplateCategory {
  PROFESSIONAL
  CREATIVE
  MODERN
  MINIMAL
  ACADEMIC
  TECHNICAL
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiToolKind {
  SUMMARY
  SKILLS
  ATS
  REVIEW
  JOB_MATCH
  TAILOR
  COVER_LETTER
  GITHUB_PROFILE_SUMMARY
  PROJECT_IMPROVEMENT
  EXPERIENCE_IMPROVEMENT
}

enum AiArtifactStatus {
  READY
  APPLIED
  DISMISSED
  FAILED
}

enum RecruiterBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum CandidateDocumentStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  FAILED
}

enum CandidateRecommendation {
  STRONG_MATCH
  POTENTIAL_MATCH
  WEAK_MATCH
}

enum CandidateLinkType {
  GITHUB
  LINKEDIN
  PORTFOLIO
  OTHER
}

enum LinkInspectionStatus {
  PENDING
  COMPLETED
  FAILED
  BLOCKED
}

// ── User ─────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique @db.VarChar(255)
  name            String   @db.VarChar(200)
  passwordHash    String   @map("password_hash") @db.VarChar(255)
  avatarUrl       String?  @map("avatar_url") @db.Text
  githubUsername   String?  @map("github_username") @db.VarChar(100)
  githubToken     String?  @map("github_token") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cvs              CV[]
  githubAnalyses   GitHubAnalysis[]
  aiArtifacts      AiArtifact[]
  recruiterJobs        RecruiterJob[]
  recruiterBatches     RecruiterBatch[]
  candidateDocuments   CandidateDocument[]
  candidateProfiles    CandidateProfile[]
  candidateEvaluations CandidateEvaluation[]

  @@map("users")
}

// ── CV ───────────────────────────────────────────────────

model CV {
  id              String    @id @default(uuid()) @db.Uuid
  title           String    @db.VarChar(200)
  slug            String    @unique @db.VarChar(300)
  status          CVStatus  @default(DRAFT)
  locale          String    @default("en") @db.VarChar(5)
  isAtsOptimized  Boolean   @default(false) @map("is_ats_optimized")
  sectionOrder    Json      @default("[]") @map("section_order")
  themeConfig     Json      @default("{}") @map("theme_config")
  userId          String    @map("user_id") @db.Uuid
  templateId      String    @map("template_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template             Template              @relation(fields: [templateId], references: [id])
  personalInfo         PersonalInfo?
  summary              Summary?
  coverLetter          CoverLetter?
  experiences          Experience[]
  educations           Education[]
  skills               Skill[]
  projects             Project[]
  certifications       Certification[]
  languages            Language[]
  volunteerExperiences VolunteerExperience[]
  publications         Publication[]
  awards               Award[]
  references           Reference[]
  hobbies              Hobby[]
  customSections       CustomSection[]
  pdfExports           PDFExport[]
  aiArtifacts          AiArtifact[]

  @@index([userId])
  @@index([templateId])
  @@index([status])
  @@map("cvs")
}

// ── Template ─────────────────────────────────────────────

model Template {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @unique @db.VarChar(100)
  slug            String            @unique @db.VarChar(150)
  description     String            @db.Text
  category        TemplateCategory
  thumbnailUrl    String?           @map("thumbnail_url") @db.Text
  previewUrl      String?           @map("preview_url") @db.Text
  structure       Json              @default("{}")
  defaultTheme    Json              @default("{}") @map("default_theme")
  isActive        Boolean           @default(true) @map("is_active")
  isPremium       Boolean           @default(false) @map("is_premium")
  supportedLayouts Json             @default("[\"SINGLE_COLUMN\"]") @map("supported_layouts")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  cvs CV[]

  @@index([category])
  @@index([isActive])
  @@map("templates")
}

// ── Personal Info ────────────────────────────────────────

model PersonalInfo {
  id                String   @id @default(uuid()) @db.Uuid
  firstName         String   @map("first_name") @db.VarChar(100)
  lastName          String   @map("last_name") @db.VarChar(100)
  professionalTitle String   @default("") @map("professional_title") @db.VarChar(200)
  email             String   @db.VarChar(255)
  phone             String   @default("") @db.VarChar(30)
  city              String   @default("") @db.VarChar(100)
  country           String   @default("") @db.VarChar(100)
  zipCode           String   @default("") @map("zip_code") @db.VarChar(20)
  dateOfBirth       String?  @map("date_of_birth") @db.VarChar(20)
  nationality       String?  @db.VarChar(100)
  website           String?  @db.Text
  linkedIn          String?  @map("linked_in") @db.Text
  github            String?  @db.Text
  twitter           String?  @db.Text
  stackoverflow     String?  @db.Text
  medium            String?  @db.Text
  behance           String?  @db.Text
  dribbble          String?  @db.Text
  profilePhotoUrl   String?  @map("profile_photo_url") @db.Text
  address           String?  @db.VarChar(300)
  cvId              String   @unique @map("cv_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@map("personal_infos")
}

// ── Summary ──────────────────────────────────────────────

model Summary {
  id          String   @id @default(uuid()) @db.Uuid
  content     String   @default("") @db.Text
  aiGenerated Boolean  @default(false) @map("ai_generated")
  cvId        String   @unique @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@map("summaries")
}

model CoverLetter {
  id          String   @id @default(uuid()) @db.Uuid
  content     String   @default("") @db.Text
  aiGenerated Boolean  @default(false) @map("ai_generated")
  cvId        String   @unique @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@map("cover_letters")
}

// ── Experience ───────────────────────────────────────────

model Experience {
  id                  String   @id @default(uuid()) @db.Uuid
  jobTitle            String   @map("job_title") @db.VarChar(200)
  company             String   @db.VarChar(200)
  companyDescription  String?  @map("company_description") @db.VarChar(500)
  location            String   @default("") @db.VarChar(200)
  startDate           String   @map("start_date") @db.VarChar(20)
  endDate             String?  @map("end_date") @db.VarChar(20)
  isCurrent           Boolean  @default(false) @map("is_current")
  description         String   @default("") @db.Text
  achievements        Json     @default("[]")
  technologies        Json     @default("[]")
  orderIndex          Int      @default(0) @map("order_index")
  cvId                String   @map("cv_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("experiences")
}

// ── Education ────────────────────────────────────────────

model Education {
  id                  String   @id @default(uuid()) @db.Uuid
  degree              String   @db.VarChar(200)
  fieldOfStudy        String   @map("field_of_study") @db.VarChar(200)
  institution         String   @db.VarChar(200)
  location            String   @default("") @db.VarChar(200)
  startDate           String   @map("start_date") @db.VarChar(20)
  endDate             String?  @map("end_date") @db.VarChar(20)
  gpa                 String?  @db.VarChar(10)
  relevantCoursework  Json     @default("[]") @map("relevant_coursework")
  achievements        Json     @default("[]")
  orderIndex          Int      @default(0) @map("order_index")
  cvId                String   @map("cv_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("educations")
}

// ── Skill ────────────────────────────────────────────────

model Skill {
  id                String           @id @default(uuid()) @db.Uuid
  name              String           @db.VarChar(100)
  category          SkillCategory
  proficiencyLevel  ProficiencyLevel @map("proficiency_level")
  yearsOfExperience Float?           @map("years_of_experience")
  orderIndex        Int              @default(0) @map("order_index")
  cvId              String           @map("cv_id") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("skills")
}

// ── Project ──────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(200)
  description    String   @default("") @db.Text
  role           String?  @db.VarChar(200)
  technologies   Json     @default("[]")
  url            String?  @db.Text
  githubUrl      String?  @map("github_url") @db.Text
  startDate      String   @map("start_date") @db.VarChar(20)
  endDate        String?  @map("end_date") @db.VarChar(20)
  highlights     Json     @default("[]")
  isFromGitHub   Boolean  @default(false) @map("is_from_github")
  githubRepoData Json?    @map("github_repo_data")
  githubAnalysisId String? @map("github_analysis_id") @db.Uuid
  orderIndex     Int      @default(0) @map("order_index")
  cvId           String   @map("cv_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cv             CV              @relation(fields: [cvId], references: [id], onDelete: Cascade)
  githubAnalysis GitHubAnalysis? @relation(fields: [githubAnalysisId], references: [id], onDelete: SetNull)

  @@index([cvId])
  @@index([githubAnalysisId])
  @@map("projects")
}

// ── Certification ────────────────────────────────────────

model Certification {
  id                   String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(200)
  issuingOrganization  String   @map("issuing_organization") @db.VarChar(200)
  issueDate            String   @map("issue_date") @db.VarChar(20)
  expirationDate       String?  @map("expiration_date") @db.VarChar(20)
  credentialId         String?  @map("credential_id") @db.VarChar(100)
  credentialUrl        String?  @map("credential_url") @db.Text
  orderIndex           Int      @default(0) @map("order_index")
  cvId                 String   @map("cv_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("certifications")
}

// ── Language ─────────────────────────────────────────────

model Language {
  id          String              @id @default(uuid()) @db.Uuid
  name        String              @db.VarChar(100)
  proficiency LanguageProficiency
  orderIndex  Int                 @default(0) @map("order_index")
  cvId        String              @map("cv_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("languages")
}

// ── Volunteer Experience ─────────────────────────────────

model VolunteerExperience {
  id           String   @id @default(uuid()) @db.Uuid
  role         String   @db.VarChar(200)
  organization String   @db.VarChar(200)
  location     String?  @db.VarChar(200)
  startDate    String   @map("start_date") @db.VarChar(20)
  endDate      String?  @map("end_date") @db.VarChar(20)
  description  String   @default("") @db.Text
  orderIndex   Int      @default(0) @map("order_index")
  cvId         String   @map("cv_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("volunteer_experiences")
}

// ── Publication ──────────────────────────────────────────

model Publication {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(300)
  publisher   String   @db.VarChar(200)
  date        String   @db.VarChar(20)
  url         String?  @db.Text
  description String?  @db.Text
  orderIndex  Int      @default(0) @map("order_index")
  cvId        String   @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("publications")
}

// ── Award ────────────────────────────────────────────────

model Award {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  issuer      String   @db.VarChar(200)
  date        String   @db.VarChar(20)
  description String?  @db.Text
  orderIndex  Int      @default(0) @map("order_index")
  cvId        String   @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("awards")
}

// ── Reference ────────────────────────────────────────────

model Reference {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(200)
  title        String   @db.VarChar(200)
  company      String   @db.VarChar(200)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(30)
  relationship String   @db.VarChar(200)
  orderIndex   Int      @default(0) @map("order_index")
  cvId         String   @map("cv_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("references")
}

// ── Hobby ────────────────────────────────────────────────

model Hobby {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  orderIndex  Int      @default(0) @map("order_index")
  cvId        String   @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("hobbies")
}

// ── Custom Section ───────────────────────────────────────

model CustomSection {
  id            String   @id @default(uuid()) @db.Uuid
  sectionTitle  String   @map("section_title") @db.VarChar(200)
  content       Json     @default("{}")
  orderIndex    Int      @default(0) @map("order_index")
  cvId          String   @map("cv_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("custom_sections")
}

// ── PDF Export ───────────────────────────────────────────

model PDFExport {
  id          String   @id @default(uuid()) @db.Uuid
  fileName    String   @map("file_name") @db.VarChar(300)
  filePath    String   @map("file_path") @db.Text
  fileSize    Int      @map("file_size")
  cvId        String   @map("cv_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  cv CV @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([cvId])
  @@map("pdf_exports")
}

// ── AI Artifact ─────────────────────────────────────────

model AiArtifact {
  id            String           @id @default(uuid()) @db.Uuid
  tool          AiToolKind
  status        AiArtifactStatus @default(READY)
  title         String           @db.VarChar(160)
  provider      String           @default("ollama") @db.VarChar(40)
  model         String           @db.VarChar(120)
  locale        String           @default("en") @db.VarChar(5)
  targetSection String?          @map("target_section") @db.VarChar(40)
  input         Json?
  output        Json?
  summary       String?          @db.Text
  error         String?          @db.Text
  appliedAt     DateTime?        @map("applied_at")
  dismissedAt   DateTime?        @map("dismissed_at")
  userId        String           @map("user_id") @db.Uuid
  cvId          String?          @map("cv_id") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv   CV?  @relation(fields: [cvId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([cvId, createdAt])
  @@index([userId, tool])
  @@map("ai_artifacts")
}

// ── GitHub Analysis ──────────────────────────────────────

model GitHubAnalysis {
  id                String         @id @default(uuid()) @db.Uuid
  username          String         @db.VarChar(100)
  repoFullName      String?        @map("repo_full_name") @db.VarChar(250)
  locale            String         @default("en") @db.VarChar(5)
  analysisVersion   String         @default("github-analysis-v2") @map("analysis_version") @db.VarChar(60)
  model             String?        @db.VarChar(120)
  status            AnalysisStatus @default(PENDING)
  result            Json?
  error             String?        @db.Text
  startedAt         DateTime?      @map("started_at")
  completedAt       DateTime?      @map("completed_at")
  lastAnalyzedAt    DateTime?      @map("last_analyzed_at")
  userId            String         @map("user_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@index([userId, repoFullName])
  @@index([userId, repoFullName, locale])
  @@index([status])
  @@unique([userId, repoFullName, locale, analysisVersion])
  @@map("github_analyses")
}

model RecruiterJob {
  id                     String   @id @default(uuid()) @db.Uuid
  title                  String   @db.VarChar(200)
  company                String?  @db.VarChar(200)
  location               String?  @db.VarChar(200)
  locale                 String   @default("en") @db.VarChar(5)
  description            String   @db.Text
  mustHaveSkills         Json     @default("[]") @map("must_have_skills")
  niceToHaveSkills       Json     @default("[]") @map("nice_to_have_skills")
  minimumYearsExperience Float?   @map("minimum_years_experience")
  userId                 String   @map("user_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batches           RecruiterBatch[]
  candidateProfiles CandidateProfile[]

  @@index([userId, createdAt])
  @@map("recruiter_jobs")
}

model RecruiterBatch {
  id              String               @id @default(uuid()) @db.Uuid
  status          RecruiterBatchStatus @default(PENDING)
  totalFiles      Int                  @default(0) @map("total_files")
  processedFiles  Int                  @default(0) @map("processed_files")
  successfulFiles Int                  @default(0) @map("successful_files")
  failedFiles     Int                  @default(0) @map("failed_files")
  lastError       String?              @map("last_error") @db.Text
  completedAt     DateTime?            @map("completed_at")
  jobId           String               @map("job_id") @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  job               RecruiterJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         CandidateDocument[]
  candidateProfiles CandidateProfile[]

  @@index([jobId, createdAt])
  @@index([userId, createdAt])
  @@map("recruiter_batches")
}

model CandidateDocument {
  id               String                  @id @default(uuid()) @db.Uuid
  originalFileName String                  @map("original_file_name") @db.VarChar(260)
  storedFileName   String                  @map("stored_file_name") @db.VarChar(260)
  mimeType         String                  @map("mime_type") @db.VarChar(120)
  filePath         String                  @map("file_path") @db.Text
  fileSize         Int                     @map("file_size")
  extractionStatus CandidateDocumentStatus @default(UPLOADED) @map("extraction_status")
  extractedText    String?                 @map("extracted_text") @db.Text
  parseError       String?                 @map("parse_error") @db.Text
  processedAt      DateTime?               @map("processed_at")
  batchId          String                  @map("batch_id") @db.Uuid
  userId           String                  @map("user_id") @db.Uuid
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  batch            RecruiterBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateProfile CandidateProfile?

  @@index([batchId, createdAt])
  @@index([userId, createdAt])
  @@map("candidate_documents")
}

model CandidateProfile {
  id                String   @id @default(uuid()) @db.Uuid
  fullName          String?  @map("full_name") @db.VarChar(200)
  headline          String?  @db.VarChar(250)
  email             String?  @db.VarChar(255)
  phone             String?  @db.VarChar(40)
  location          String?  @db.VarChar(200)
  yearsOfExperience Float?   @map("years_of_experience")
  summary           String?  @db.Text
  topSkills         Json     @default("[]") @map("top_skills")
  completenessScore Int      @default(0) @map("completeness_score")
  missingFields     Json     @default("[]") @map("missing_fields")
  rawTextSnippet    String   @map("raw_text_snippet") @db.Text
  jobId             String   @map("job_id") @db.Uuid
  batchId           String   @map("batch_id") @db.Uuid
  documentId        String   @unique @map("document_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  job        RecruiterJob        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  batch      RecruiterBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  document   CandidateDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  links      CandidateLink[]
  evaluation CandidateEvaluation?

  @@index([jobId, createdAt])
  @@index([batchId, createdAt])
  @@index([userId, createdAt])
  @@map("candidate_profiles")
}

model CandidateLink {
  id                 String               @id @default(uuid()) @db.Uuid
  url                String               @db.Text
  normalizedUrl      String               @map("normalized_url") @db.Text
  host               String               @db.VarChar(255)
  linkType           CandidateLinkType    @map("link_type")
  inspectionStatus   LinkInspectionStatus @default(PENDING) @map("inspection_status")
  statusCode         Int?                 @map("status_code")
  finalUrl           String?              @map("final_url") @db.Text
  title              String?              @db.VarChar(300)
  description        String?              @db.Text
  accessible         Boolean?
  responseTimeMs     Int?                 @map("response_time_ms")
  error              String?              @db.Text
  candidateProfileId String               @map("candidate_profile_id") @db.Uuid
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)

  @@index([candidateProfileId])
  @@map("candidate_links")
}

model CandidateEvaluation {
  id                 String                 @id @default(uuid()) @db.Uuid
  overallScore       Int                    @map("overall_score")
  mustHaveScore      Int                    @map("must_have_score")
  keywordScore       Int                    @map("keyword_score")
  experienceScore    Int                    @map("experience_score")
  readabilityScore   Int                    @map("readability_score")
  linkQualityScore   Int                    @map("link_quality_score")
  riskPenalty        Int                    @map("risk_penalty")
  recommendation     CandidateRecommendation
  matchedKeywords    Json                   @default("[]") @map("matched_keywords")
  matchedHardSkills  Json                   @default("[]") @map("matched_hard_skills")
  missingKeywords    Json                   @default("[]") @map("missing_keywords")
  missingHardSkills  Json                   @default("[]") @map("missing_hard_skills")
  matchEvidence      Json                   @default("[]") @map("match_evidence")
  strengths          Json                   @default("[]")
  riskFlags          Json                   @default("[]") @map("risk_flags")
  shortSummary       String                 @map("short_summary") @db.Text
  explanation        String?                @db.Text
  evaluatedAt        DateTime               @default(now()) @map("evaluated_at")
  candidateProfileId String                 @unique @map("candidate_profile_id") @db.Uuid
  userId             String                 @map("user_id") @db.Uuid
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  candidateProfile CandidateProfile @relation(fields: [candidateProfileId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, overallScore])
  @@map("candidate_evaluations")
}
