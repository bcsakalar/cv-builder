# ═══════════════════════════════════════════════════════════
# CvBuilder — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=cvbuilder
POSTGRES_PASSWORD=cvbuilder_secret
POSTGRES_DB=cvbuilder
POSTGRES_PORT=5432
DATABASE_URL=postgresql://cvbuilder:cvbuilder_secret@localhost:5432/cvbuilder?schema=public

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@localhost:6379

# ── Ollama (Local LLM) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_CODE_MODEL=codellama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_PORT=11434

# ── Security ─────────────────────────────────────────────
JWT_SECRET=change_me_in_production_jwt_secret_key
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=change_me_32_char_encryption_key!

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── GitHub OAuth (optional, preferred over PAT) ──────────
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3001/api/github/oauth/callback

# ── Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
RECRUITER_MAX_BATCH_FILES=100
RECRUITER_MAX_PDF_SIZE=10485760
RECRUITER_LINK_TIMEOUT_MS=5000
RECRUITER_LINK_MAX_REDIRECTS=3
RECRUITER_BATCH_CONCURRENCY=2

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend ─────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
